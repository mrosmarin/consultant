{
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "gh *",
      "docker *"
    ],
    "filesystem": {
      "denyRead": [
        "~/.aws/credentials",
        "~/.config/gcloud/**"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "registry.npmjs.org"
      ],
      "allowLocalBinding": true
    }
  },
  "permissions": {
    "allow": [
      "Bash(cd *)",
      "Bash(sed *)",
      "Bash(mkdir *)"
    ]
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true
  }
}