# Copy to apps/web/.env.local and fill in. Never commit .env.local.

# Dev server port. The worktree helper sets this per-worktree to avoid collisions.
PORT=3000

# Supabase — values come from `pnpm supabase status` (local) or the Supabase dashboard (cloud).
# Wired up in DEV-85. Public values are exposed to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — never expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=
