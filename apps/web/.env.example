# Copy to apps/web/.env.local and fill in. Never commit .env.local.

# Dev server port. The worktree helper sets this per-worktree to avoid collisions.
PORT=3000

# Neon Postgres connection strings — from the Vercel<->Neon integration or the
# Neon dashboard (Connection Details).
#   DATABASE_URL          = POOLED connection (app / serverless runtime).
#   DATABASE_URL_UNPOOLED = DIRECT connection (migrations / drizzle-kit).
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Neon Auth (Better Auth). Wired up in DEV-85.
#   NEON_AUTH_BASE_URL       = your Neon Auth server URL.
#   NEON_AUTH_COOKIE_SECRET  = >= 32 chars, signs session cookies.
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Canonical site origin for SEO (metadata canonical/OG, sitemap, robots).
# Defaults to the Vercel production URL; set to https://endlessworlds.xyz at launch.
NEXT_PUBLIC_SITE_URL=
